{
  "enabled": true,
  "network": {
    "allowedDomains": ["*.com", "*.dev", "*.io"],
    "deniedDomains": []
  },
  "filesystem": {
    "allowRead": [".", "~/src"],
    "allowWrite": [".", "/tmp"],
    "denyRead": ["~/.ssh", "~/.zshrc.d", "~/Sync", "~/Documents", "~/Downloads"],
    "denyWrite": [".env", ".env.*", "*.pem", "*.key", "~/.pi", ".pi", "sandbox.json"]
  }
}
